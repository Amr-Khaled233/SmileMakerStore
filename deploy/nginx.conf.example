# Hostinger VPS — nginx reverse proxy for SmileMaker.
# 1) Replace yourdomain.com with your real domain.
# 2) Save as: /etc/nginx/sites-available/smilemaker
# 3) Enable:  sudo ln -s /etc/nginx/sites-available/smilemaker /etc/nginx/sites-enabled/
# 4) Test:    sudo nginx -t  &&  sudo systemctl reload nginx
# 5) HTTPS:   sudo certbot --nginx -d yourdomain.com -d www.yourdomain.com
#    (certbot rewrites this file to add the SSL listener automatically.)

server {
    listen 80;
    server_name yourdomain.com www.yourdomain.com;

    # Allow large image uploads from the dashboard (base64 can be big).
    client_max_body_size 20M;

    location / {
        proxy_pass         http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}
