# ─── Backend (Railway) ────────────────────────────────────────────
# MongoDB connection string from Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority&appName=SmileMaker

# JWT secret — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-string

# Dashboard password
MANAGER_PASSWORD=your-strong-password-here

# Allowed frontend origins (comma-separated)
FRONTEND_URL=http://localhost:5173,https://your-app.vercel.app,https://yourdomain.com

# Port (Railway sets this automatically)
PORT=3001

# ─── Frontend (Vercel env var) ────────────────────────────────────
# Full URL of your Railway backend
VITE_API_BASE=https://your-app.up.railway.app/api
