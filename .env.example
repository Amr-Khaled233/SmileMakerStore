# ─── Database ─────────────────────────────────────────────────────
# Single-VPS setup: local MongoDB installed on the same server.
MONGODB_URI=mongodb://127.0.0.1:27017/smilemaker
# (Alternative: MongoDB Atlas → mongodb+srv://USER:PASS@cluster.mongodb.net/smilemaker)

# JWT secret — use a long random string (generate with: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-string

# Dashboard (manager) password
MANAGER_PASSWORD=your-strong-password-here

# Public domain(s) of the frontend, comma-separated. Used for CORS — the
# frontend and API are on different domains (backend-smile.alisoliman.net),
# so this must list the frontend's real origin(s) exactly.
FRONTEND_URL=https://smile.alisoliman.net

# Port the Node server listens on (Traefik proxies to this)
PORT=3001

# ─── Cloudinary (OPTIONAL) ─────────────────────────────────────────
# Leave these EMPTY to store images in MongoDB (each image as its own
# document, served from /api/images/<id>) — recommended for a self-contained
# single-VPS setup. Only fill these in if you'd rather offload images to
# Cloudinary's CDN.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ─── Frontend ─────────────────────────────────────────────────────
# NOT read from this file by the build — frontend and backend are separate
# containers on different domains, so VITE_API_BASE is baked in at build time
# as a Docker build arg (see the `frontend` service in docker-compose.yml),
# defaulting to https://backend-smile.alisoliman.net. Optionally export
# VITE_API_BASE in your shell before `docker compose up` to override it.
